# ---------------------------------------------------------------------------
# Frontend Application Configuration
# ---------------------------------------------------------------------------

# Port for the Vite development server to run on
VITE_PORT=8081

# Target URL for the API proxy (Your backend server URL)
VITE_PROXY_TARGET=http://142.93.167.9:8010

# Base URL for API requests (usually matches the proxy path)
VITE_API_BASE_URL=/api/v1

# ---------------------------------------------------------------------------
# App Display Settings
# ---------------------------------------------------------------------------
# The name of the application displayed in the UI
VITE_APP_NAME="Communication System"

# Support email address shown to users
VITE_SUPPORT_EMAIL=support@yourdomain.com

# Name of the AI or support assistant interacting with users
VITE_ASSISTANT_NAME="Support Assistant"

# ---------------------------------------------------------------------------
# Widget Welcome Screen Content
# ---------------------------------------------------------------------------
VITE_WELCOME_TITLE="Hi There!"
VITE_WELCOME_SUBTITLE="How can we help?"
VITE_WELCOME_PROMPT="Please select an option below"
VITE_WELCOME_CHAT_BTN="Chat with us"
VITE_WELCOME_FOLLOW_BTN="Follow previous request"

# ---------------------------------------------------------------------------
# Role System
# ---------------------------------------------------------------------------
# Configure role identifiers mapping to your backend setup
VITE_ROLE_DEV="dev"
VITE_ROLE_USER="user"

# Default user configuration (for development / testing / demo purposes)
VITE_DEFAULT_USER_ID=1
VITE_DEFAULT_USER_NAME="Developer"

# ---------------------------------------------------------------------------
# Dynamic Frontend Options (comma-separated lists)
# ---------------------------------------------------------------------------
# Options provided on the support widget for follow-ups
VITE_FOLLOW_UP_OPTIONS="change request status,bug report status,support request,Update a previous change request,payment issue,complaint"

# Tags available for clients submitting change requests
VITE_MODIFICATION_TAGS="Frontend,Backend Logic,Database,Integration,API Modification,Bug Fix,Performance Improvement,Security Update,Add New Feature,Custom Business Logic"
